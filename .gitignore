# Node.js
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.eslintcache
coverage/
.nyc_output/

# State runtime — runtime databases
state/orchestrator.db
state/orchestrator.db-wal
state/orchestrator.db-shm
state/db.sqlite
state/goose.db

# State runtime — control files
state/.SESSIONS_DISABLED

# Benchmarks / measurements (ephemeral)
state/benchmark-*.json

# Playwright MCP recordings (ephemeral debug artifacts)
.playwright-mcp/

# State runtime — logs
state/logs/*.log
state/logs/*.out
state/logs/*.err

# State runtime — conversations and events
state/conversations/*.jsonl

# State runtime — inbox/outbox (ephemeral inputs)
state/inbox/*.input
state/inbox/*.json

# State runtime — artifacts (generated during task execution)
state/artifacts/

# State runtime — backups (excluded from repo, managed separately)
state/backups/

# State runtime — heartbeat and control files
state/.heartbeat
state/.KILLSWITCH
state/.migration.lock

# State runtime — reports (generated dashboards)
state/reports/

# State runtime — outbox (outputs staged for delivery)
state/outbox/

# Secrets — NEVER commit unencrypted secrets
state/secrets/anthropic.env
state/secrets/keys/*.txt
*.env
*.env.local
.env*.local

# Secrets — KEEP encrypted versions
!state/secrets/anthropic.env.enc
!state/secrets/keys/.gitkeep

# Editor / IDE
.DS_Store
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
._*

# PM2
.pm2/
ecosystem.config.local.js
pids/
*.pid
*.seed
*.pid.lock

# Temporary files
tmp/
temp/
*.tmp
.cache/
